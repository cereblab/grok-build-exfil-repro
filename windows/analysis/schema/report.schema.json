{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/egress-report-v1.schema.json",
  "title": "Windows egress evidence report",
  "type": "object",
  "required": [
    "schema_version",
    "capture_status",
    "client_version",
    "capture_outcome",
    "output_layout",
    "http_request_count",
    "websocket_message_count",
    "http_request_bytes",
    "websocket_message_bytes",
    "client_launched",
    "proxy_started",
    "monitoring_started",
    "run_metadata",
    "evidence_integrity",
    "raw_files_processed",
    "derived_artifacts_created",
    "decoding_operations",
    "decoding_failures",
    "canary_inventory_sources",
    "canary_findings",
    "canary_direction_summary",
    "allowed_file_first_line_summary",
    "git_candidate_findings",
    "git_validation_results",
    "limitations",
    "untested_assumptions"
  ],
  "properties": {
    "schema_version": {"const": "egress-report/v1"},
    "capture_status": {
      "enum": [
        "CAPTURE_VALIDATED",
        "PARTIAL_CAPTURE",
        "TLS_INTERCEPTION_FAILED",
        "DIRECT_BYPASS_DETECTED",
        "NO_AGENT_TRAFFIC_OBSERVED",
        "CAPTURE_START_FAILED",
        "CLIENT_EXECUTION_FAILED",
        "CAPTURE_FAILED",
        "NOT_EVALUATED"
      ]
    },
    "client_version": {"type": ["string", "null"]},
    "capture_outcome": {
      "type": "object",
      "properties": {
        "final_status": {"type": "string"},
        "launcher_exit_code": {"type": ["integer", "null"]},
        "mitmdump_exit_code": {"type": ["integer", "null"]},
        "launcher_final_status": {"type": "string"},
        "shutdown_error_observed": {"type": "boolean"},
        "shutdown_error_classification": {"type": "string"},
        "capture_integrity_affected": {"type": ["boolean", "null"]},
        "client_completion_timestamp": {"type": ["string", "null"]},
        "shutdown_request_timestamp": {"type": ["string", "null"]},
        "proxy_termination_timestamp": {"type": ["string", "null"]},
        "listener_release_timestamp": {"type": ["string", "null"]},
        "runtime_error_timeline": {"type": "array"},
        "runtime_error_timing_summary": {"type": "object"},
        "final_status_reason": {"type": "string"}
      }
    },
    "output_layout": {
      "type": "object",
      "required": [
        "output_root",
        "control_directory",
        "raw_directory",
        "analysis_directory",
        "report_directory"
      ],
      "properties": {
        "output_root": {"type": "string"},
        "control_directory": {"type": "string"},
        "raw_directory": {"type": "string"},
        "analysis_directory": {"type": "string"},
        "report_directory": {"type": "string"}
      },
      "additionalProperties": false
    },
    "http_request_count": {"type": "integer", "minimum": 0},
    "websocket_message_count": {"type": "integer", "minimum": 0},
    "http_request_bytes": {"type": "integer", "minimum": 0},
    "websocket_message_bytes": {"type": "integer", "minimum": 0},
    "client_launched": {"type": "boolean"},
    "proxy_started": {"type": "boolean"},
    "monitoring_started": {"type": "boolean"},
    "run_metadata": {"type": "object"},
    "evidence_integrity": {"type": "object"},
    "raw_files_processed": {"type": "array"},
    "derived_artifacts_created": {"type": "array"},
    "decoding_operations": {"type": "array"},
    "decoding_failures": {"type": "array"},
    "unsupported_encodings": {"type": "array"},
    "processing_limits_reached": {"type": "array"},
    "canary_inventory_sources": {"type": "array"},
    "canary_findings": {"type": "array"},
    "canary_direction_summary": {
      "type": "object",
      "required": [
        "client_to_server_occurrences",
        "server_to_client_occurrences",
        "other_or_unknown_occurrences"
      ],
      "properties": {
        "client_to_server_occurrences": {"type": "integer", "minimum": 0},
        "server_to_client_occurrences": {"type": "integer", "minimum": 0},
        "other_or_unknown_occurrences": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "allowed_file_first_line_summary": {
      "type": "object",
      "required": [
        "client_to_server_occurrences",
        "server_to_client_occurrences",
        "other_or_unknown_occurrences"
      ],
      "properties": {
        "client_to_server_occurrences": {"type": "integer", "minimum": 0},
        "server_to_client_occurrences": {"type": "integer", "minimum": 0},
        "other_or_unknown_occurrences": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "canary_summary": {"type": "string"},
    "git_candidate_findings": {"type": "array"},
    "git_validation_results": {"type": "object"},
    "client_execution": {"type": "object"},
    "capture_coverage": {"type": "object"},
    "limitations": {"type": "array", "items": {"type": "string"}},
    "untested_assumptions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
